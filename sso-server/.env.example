APP_NAME="SSO Server"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
# Create database/database.sqlite or switch to mysql below
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=sso
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

SSO_JWT_SECRET=please-change-me-shared-with-clients
SSO_JWT_TTL=3600
SSO_ALLOWED_REDIRECTS="http://localhost:8001/sso/callback,http://localhost:8002/sso/callback"
